# x-use LLM API keys. Copy this file to ".env" and fill in what you use.
#
# Precedence: environment variables (process env or this .env file) override
# the api_keys in config/settings.json — env > settings.json. Placeholder
# values (e.g. "YOUR_OPENAI_API_KEY") are rejected from BOTH sources, and a
# provider without a valid key is simply not initialized.
# .env is gitignored; never commit real keys.
#
# Note: ${VAR} interpolation inside proxy strings in config/settings.json is a
# separate mechanism that reads the process environment — it remains
# proxy-strings-only and is unrelated to the keys below.

OPENAI_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
